spec:
  additionalNetworks:
{% for network in ipv6_secondary_networks.networks %}
  - name: {{ network.net_name }}
    namespace: {{ network.net_name }}
    rawCNIConfig: |-
      {
        "cniVersion": "0.3.1",
        "name": "{{ network.net_name }}",
        "type": "macvlan",
        "master": "{{ ipv6_interfaces[loop.index0] }}"
      }
    type: Raw
{% endfor %}
